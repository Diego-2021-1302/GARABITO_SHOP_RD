# Garabito Shop RD - Configuración de Producción
APP_NAME="Garabito Shop RD"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.tu-dominio.com
FRONTEND_URL=https://tu-dominio.com

LOG_CHANNEL=daily
LOG_LEVEL=info

# Base de Datos (Recomendado: Postgres o MySQL)
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=garabito_shop
DB_USERNAME=postgres
DB_PASSWORD=password

# Cache y Sesiones (Recomendado: Redis)
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Correo (Para facturas y notificaciones)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@garabitoshop.do"
MAIL_FROM_NAME="${APP_NAME}"

# Almacenamiento
FILESYSTEM_DISK=public

# Seguridad
BCRYPT_ROUNDS=12
