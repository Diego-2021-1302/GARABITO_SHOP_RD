{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api-garabito.onrender.com/api/:path*"
    },
    {
      "source": "/storage/:path*",
      "destination": "https://api-garabito.onrender.com/storage/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
